{
  "name": "pi-cortex",
  "private": true,
  "version": "0.1.0-pre",
  "description": "Cortex extension for pi.dev: exposes cortex_recall as a tool and hooks tool_call back to cortex capture. Phase 8 of the cortex eval-harness program.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions/cortex/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --test --experimental-strip-types --experimental-test-coverage=false test/**/*.test.ts"
  },
  "dependencies": {
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
